{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/success",
      "dest": "/public/success.html"
    },
    {
      "src": "/cancel",
      "dest": "/public/cancel.html"
    },
    {
      "src": "/(.*)\\.html",
      "dest": "/public/$1.html"
    },
    {
      "src": "/(.*)\\.css",
      "dest": "/public/$1.css"
    },
    {
      "src": "/(.*)\\.js",
      "dest": "/public/$1.js"
    },
    {
      "src": "/(.*)\\.png",
      "dest": "/public/$1.png"
    },
    {
      "src": "/(.*)\\.ico",
      "dest": "/public/$1.ico"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1",
      "status": 200
    },
    {
      "src": "/404",
      "dest": "/public/404.html",
      "status": 404
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://js.stripe.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.googleapis.com https://js.stripe.com; frame-src https://js.stripe.com;"
        }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}